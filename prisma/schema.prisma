datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  users      User[]
  created_at DateTime @default(now())

  @@map("roles")
}

model User {
  id            Int           @id @default(autoincrement())
  role_id       Int
  role          Role          @relation(fields: [role_id], references: [id])
  name          String
  email         String        @unique
  password      String
  activity_logs ActivityLog[]
  created_at    DateTime      @default(now())

  @@map("users")
}

model TempleCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String   @db.Text
  temples     Temple[]
  created_at  DateTime @default(now())

  @@map("temple_categories")
}

model Temple {
  id          Int            @id @default(autoincrement())
  category_id Int
  category    TempleCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  name        String
  slug        String         @unique
  description String         @db.Text
  location    String
  thumbnail   String
  status      String         @default("Active")
  created_at  DateTime       @default(now())

  @@map("temples")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action     String   @db.Text
  created_at DateTime @default(now())

  @@map("activity_logs")
}
